{"ast":null,"code":"import{useState,useEffect,useCallback}from'react';import api from'../../utils/api';export const useLogProjects=()=>{const[projects,setProjects]=useState([]);const[loading,setLoading]=useState(true);const[error,setError]=useState(null);const fetchProjects=useCallback(async()=>{try{setLoading(true);const response=await api.get('/logs/projects');if(response.data.success){setProjects(response.data.data);}setError(null);}catch(err){setError(err.message);console.error('Error fetching projects:',err);}finally{setLoading(false);}},[]);useEffect(()=>{fetchProjects();},[fetchProjects]);return{projects,loading,error,refetch:fetchProjects};};","map":{"version":3,"names":["useState","useEffect","useCallback","api","useLogProjects","projects","setProjects","loading","setLoading","error","setError","fetchProjects","response","get","data","success","err","message","console","refetch"],"sources":["/www/wwwroot/main-landing-page-frontend/src/hooks/logs/useLogProjects.js"],"sourcesContent":["import { useState, useEffect, useCallback } from 'react';\r\nimport api from '../../utils/api';\r\n\r\nexport const useLogProjects = () => {\r\n  const [projects, setProjects] = useState([]);\r\n  const [loading, setLoading] = useState(true);\r\n  const [error, setError] = useState(null);\r\n\r\n  const fetchProjects = useCallback(async () => {\r\n    try {\r\n      setLoading(true);\r\n      const response = await api.get('/logs/projects');\r\n      if (response.data.success) {\r\n        setProjects(response.data.data);\r\n      }\r\n      setError(null);\r\n    } catch (err) {\r\n      setError(err.message);\r\n      console.error('Error fetching projects:', err);\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  }, []);\r\n\r\n  useEffect(() => {\r\n    fetchProjects();\r\n  }, [fetchProjects]);\r\n\r\n  return { projects, loading, error, refetch: fetchProjects };\r\n};"],"mappings":"AAAA,OAASA,QAAQ,CAAEC,SAAS,CAAEC,WAAW,KAAQ,OAAO,CACxD,MAAO,CAAAC,GAAG,KAAM,iBAAi